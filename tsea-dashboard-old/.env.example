# ─── RFID Authentication ─────────────────────────────────
# Salt para derivação PBKDF2 do UID do crachá
# OBRIGATÓRIO — deve ser o mesmo valor em todos os terminais da fábrica
VITE_RFID_SALT=tsea-rfid-change-me-in-production

# ─── Inactivity Timeout ───────────────────────────────────
# Tempo em ms até logout automático por inatividade (padrão: 5 minutos)
VITE_INACTIVITY_TIMEOUT_MS=300000

# ─── Supabase (desativado em dev — ativar na entrega de produção) ─
# VITE_SUPABASE_URL=https://sua-instancia.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# VITE_STORAGE_BUCKET=tsea-documents
